---
// Teams.astro
const teams = [
  {
    name: '1. Mannschaft',
    league: 'Verbandsliga Nord-Ost',
    description: 'Unsere erste Mannschaft spielt in der Verbandsliga Nord-Ost – der zweithöchsten Amateurklasse des Saarlandes.',
    fupaUrl: 'https://www.fupa.net/verein/vfl-primstal',
    icon: '⚽',
    accent: true,
  },
  {
    name: '2. Mannschaft',
    league: 'Landesliga Nord',
    description: 'Die zweite Mannschaft in der Landesliga Nord bietet eine starke Wettkampfplattform für talentierte Spieler.',
    fupaUrl: 'https://www.fupa.net/verein/vfl-primstal',
    icon: '⚽',
    accent: false,
  },
  {
    name: 'Alte Herren',
    league: 'Freizeitfußball',
    description: 'Fußball kennt kein Alter! Die Alten Herren pflegen Leidenschaft und Kameradschaft auf und neben dem Platz.',
    icon: '🎖️',
    accent: false,
  },
  {
    name: 'Jugend',
    league: 'JFG Schaumberg-Prims',
    description: 'Nachwuchsförderung von der G-Jugend (U7) bis zur A-Jugend im Rahmen der JFG Schaumberg-Prims.',
    icon: '🌟',
    accent: false,
  },
];
---

<section id="teams" class="teams">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Unsere Mannschaften</h2>
      <p class="section-subtitle">Vom Nachwuchs bis zu den Aktiven – der VfL Primstal bietet für jeden das Richtige.</p>
    </div>

    <div class="teams-grid">
      {teams.map((team) => (
        <div class={"team-card" + (team.accent ? " team-card--accent" : "")}>
          <div class="team-icon-wrap">
            <span class="team-icon">{team.icon}</span>
          </div>
          <h3 class="team-name">{team.name}</h3>
          <span class="league-badge">{team.league}</span>
          <p class="team-desc">{team.description}</p>
          {team.fupaUrl && (
            <a href={team.fupaUrl} target="_blank" rel="noopener noreferrer" class="card-link">
              Spielplan &amp; Tabelle &rarr;
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .teams {
    background: var(--color-bg);
    padding: 6rem 0;
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .team-card {
    background: var(--color-surface);
    border-radius: 12px;
    border: 1px solid var(--color-border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.2s, border-color 0.2s;
  }

  .team-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-accent);
  }

  .team-card--accent {
    border-top: 3px solid var(--color-red);
  }

  .team-icon-wrap {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--color-red-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .team-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .league-badge {
    display: inline-block;
    background: var(--color-red-glow);
    color: var(--color-red);
    border-radius: 20px;
    padding: 0.2rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    margin: 0.25rem 0;
    align-self: flex-start;
  }

  .team-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0.25rem 0 0;
    flex: 1;
  }

  .card-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-red);
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-link:hover {
    color: var(--color-red-light);
    text-decoration: underline;
  }
</style>
