---
// Contact.astro
---

<section id="contact" class="contact">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Kontakt</h2>
      <p class="section-subtitle">Fragen, Anregungen oder Interesse am Verein? Wir freuen uns von euch zu hören.</p>
    </div>

    <div class="contact-card">
      <!-- Club identity -->
      <div class="card-top">
        <p class="club-name">VfL Primstal e.V.</p>
        <p class="club-location">Nonnweiler-Primstal, Saarland</p>
      </div>

      <hr class="divider" />

      <!-- Contact rows -->
      <div class="contact-row">
        <div class="contact-icon-wrap">
          <span>📧</span>
        </div>
        <div class="contact-info">
          <span class="contact-label">E-Mail</span>
          <span class="contact-value">[E-MAIL EINTRAGEN]</span>
        </div>
      </div>

      <div class="contact-row">
        <div class="contact-icon-wrap">
          <span>📞</span>
        </div>
        <div class="contact-info">
          <span class="contact-label">Telefon</span>
          <span class="contact-value">[TELEFON EINTRAGEN]</span>
        </div>
      </div>

      <hr class="divider" />

      <!-- Social media -->
      <div class="social-row">
        <p class="social-label">Findet uns auch auf:</p>
        <div class="social-icons">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/vflprimstal"
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/vflprimstal"
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-bg-alt);
    padding: 6rem 0;
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .contact-card {
    max-width: 600px;
    margin: 0 auto;
    background: var(--color-surface);
    border-radius: 16px;
    padding: 3rem;
    border: 1px solid var(--color-border);
  }

  .card-top {
    margin-bottom: 1.5rem;
  }

  .club-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.35rem;
  }

  .club-location {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-row:last-of-type {
    border-bottom: none;
  }

  .contact-icon-wrap {
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 50%;
    background: var(--color-red-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .contact-value {
    font-size: 0.95rem;
    color: var(--color-text);
    font-weight: 500;
  }

  /* Social row */
  .social-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .social-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .social-icons {
    display: flex;
    gap: 0.75rem;
  }

  .social-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-surface-hover);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .social-btn:hover {
    border-color: var(--color-red);
    color: var(--color-red);
    background: var(--color-red-glow);
  }
</style>
