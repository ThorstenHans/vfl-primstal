<svg xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 480 340"
     width="100%" height="100%"
     preserveAspectRatio="xMidYMid slice"
     role="img"
     aria-label="Vereinsregion Saarland – VfL Primstal">
  <defs>
    <filter id="regionGlow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="0" stdDeviation="10" flood-color="#c8102e" flood-opacity="0.22"/>
    </filter>
    <filter id="pinShadow" x="-80%" y="-80%" width="260%" height="260%">
      <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#c8102e" flood-opacity="0.45"/>
    </filter>
    <pattern id="dotGrid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="10" cy="10" r="0.75" fill="#1c1c1c"/>
    </pattern>
  </defs>

  <!-- Background -->
  <rect width="480" height="340" fill="#131313"/>
  <!-- Subtle dot texture -->
  <rect width="480" height="340" fill="url(#dotGrid)"/>

  <!-- Saarland polygon (with outer glow via drop-shadow filter) -->
  <path
    d="M 90,148 L 72,112 L 92,98 L 130,83 L 172,72 L 218,68 L 270,70 L 320,80 L 362,98 L 380,130 L 382,172 L 366,210 L 338,244 L 298,270 L 248,284 L 196,280 L 152,264 L 112,240 L 80,208 L 72,172 Z"
    fill="rgba(200,16,46,0.08)"
    stroke="#c8102e"
    stroke-width="1.75"
    stroke-linejoin="round"
    filter="url(#regionGlow)"
  />

  <!-- SAARLAND label (muted, centered inside polygon) -->
  <text
    x="230" y="210"
    text-anchor="middle"
    fill="#c8102e"
    font-size="24"
    font-family="Inter,system-ui,-apple-system,sans-serif"
    font-weight="800"
    letter-spacing="0.14em"
    opacity="0.20"
  >SAARLAND</text>

  <!-- Primstal map pin — tip lands at approx (238, 105) -->
  <g transform="translate(238, 83)" filter="url(#pinShadow)">
    <path d="M0,-16 C-10,-16 -16,-8 -16,0 C-16,10 0,22 0,22 C0,22 16,10 16,0 C16,-8 10,-16 0,-16 Z"
          fill="#c8102e"/>
    <circle cx="0" cy="0" r="5.5" fill="rgba(255,255,255,0.20)"/>
    <circle cx="0" cy="0" r="2.5" fill="rgba(255,255,255,0.40)"/>
  </g>
  <!-- Primstal label pill -->
  <rect x="213" y="109" width="52" height="13" rx="3" fill="rgba(13,13,13,0.82)"/>
  <text x="239" y="119"
        text-anchor="middle"
        fill="#777"
        font-size="7.5"
        font-family="Inter,system-ui,sans-serif"
        font-weight="600"
        letter-spacing="0.6">PRIMSTAL</text>

  <!-- Compass rose (upper right) -->
  <g transform="translate(448, 32)">
    <circle cx="0" cy="0" r="20" fill="rgba(19,19,19,0.92)" stroke="#2e2e2e" stroke-width="1.5"/>
    <!-- N needle (red, pointing up) -->
    <path d="M0,-18 L5,0 L0,-4 L-5,0 Z" fill="#c8102e"/>
    <!-- S needle (dark) -->
    <path d="M0,18 L5,0 L0,4 L-5,0 Z" fill="#383838"/>
    <!-- E / W tick marks -->
    <line x1="14" y1="0" x2="19" y2="0" stroke="#383838" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="-14" y1="0" x2="-19" y2="0" stroke="#383838" stroke-width="1.5" stroke-linecap="round"/>
    <!-- Centre dot -->
    <circle cx="0" cy="0" r="2.5" fill="#555"/>
    <!-- N label (sits just above the circle rim) -->
    <text x="0" y="-22"
          text-anchor="middle"
          fill="#c8102e"
          font-size="7.5"
          font-family="Inter,system-ui,sans-serif"
          font-weight="700">N</text>
  </g>
</svg>
