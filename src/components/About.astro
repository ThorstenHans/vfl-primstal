---
// About.astro
---

<section id="about" class="about">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Über uns</h2>
      <p class="section-subtitle">Der VfL Primstal – ein Verein mit Geschichte, Herz und Zukunft.</p>
    </div>

    <div class="about-grid">
      <!-- Left: Club card with stats -->
      <div class="about-card">
        <p class="about-description">
          Seit 1931 leben wir Fußball im Herzen des Saarlandes. Der VfL Primstal
          steht für Leidenschaft, Gemeinschaft und sportliche Exzellenz – auf dem
          Platz und abseits davon.
        </p>

        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-icon">🗓️</span>
            <span class="stat-label">Gegründet</span>
            <span class="stat-value">1931</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">📍</span>
            <span class="stat-label">Heimat</span>
            <span class="stat-value">Nonnweiler-Primstal</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">🏟️</span>
            <span class="stat-label">Stadion</span>
            <span class="stat-value">Allerswaldstadion</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">❤️</span>
            <span class="stat-label">Saison</span>
            <span class="stat-value">Saarland</span>
          </div>
        </div>
      </div>

      <!-- Right: Feature highlights -->
      <div class="features">
        <div class="feature-card">
          <div class="feature-icon-wrap">
            <span class="feature-icon">⚽</span>
          </div>
          <div class="feature-body">
            <h3 class="feature-title">Aktiver Fußball</h3>
            <p class="feature-desc">Von der G-Jugend bis zur Verbandsliga – bei uns kickt jeder.</p>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon-wrap">
            <span class="feature-icon">🤝</span>
          </div>
          <div class="feature-body">
            <h3 class="feature-title">Starke Gemeinschaft</h3>
            <p class="feature-desc">Mehr als ein Verein – wir sind eine Familie aus Primstal und Umgebung.</p>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon-wrap">
            <span class="feature-icon">🏆</span>
          </div>
          <div class="feature-body">
            <h3 class="feature-title">Stolze Geschichte</h3>
            <p class="feature-desc">Seit 1931 schreiben wir Sportgeschichte im Saarland.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--color-bg-alt);
    padding: 6rem 0;
  }

  .section-header {
    margin-bottom: 3.5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* Left column – about card */
  .about-card {
    background: var(--color-surface);
    border-radius: 12px;
    padding: 2.5rem;
    border: 1px solid var(--color-border);
  }

  .about-description {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 0.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-icon {
    font-size: 1.25rem;
    margin-bottom: 0.15rem;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .stat-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
  }

  /* Right column – feature cards */
  .features {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .feature-card {
    background: var(--color-surface);
    border-left: 3px solid var(--color-red);
    border-radius: 0 8px 8px 0;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    transition: background 0.2s;
  }

  .feature-card:last-child {
    margin-bottom: 0;
  }

  .feature-card:hover {
    background: var(--color-surface-hover);
  }

  .feature-icon-wrap {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: 50%;
    background: var(--color-red-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .feature-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
