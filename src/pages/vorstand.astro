---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { members, praesidium } from "../config/vorstand";
---

<Layout
    title="Vorstand – VfL Primstal"
    description="Der Vorstand des VfL Primstal e.V. – die Menschen hinter dem Verein."
>
    <Header />

    <main class="vorstand-main">
        <section class="page-hero">
            <div class="container">
                <span class="hero-badge">Unser Verein</span>
                <h1 class="hero-title">Der Vorstand</h1>
                <p class="hero-subtitle">
                    Diese engagierten Menschen führen den VfL Primstal e.V. und
                    sorgen dafür, dass unser Verein auf und neben dem Platz
                    reibungslos funktioniert.
                </p>
            </div>
        </section>

        <section class="board-section">
            <div class="container">
                <!-- ─── Präsidium ─────────────────────────────────────────── -->
                <div class="praesidium-section">
                    <div class="section-header">
                        <h2 class="subsection-title">Das Präsidium</h2>
                        <p class="subsection-subtitle">
                            Die drei Vorsitzenden führen den Verein.
                        </p>
                    </div>

                    <div class="praesidium-grid">
                        {
                            praesidium.map((member) => (
                                <article class="praesidium-card">
                                    <div class="praesidium-img-wrap">
                                        <img
                                            src={member.imageUrl}
                                            alt={`${member.firstname} ${member.lastname}`}
                                            class="praesidium-img"
                                            width="200"
                                            height="200"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="praesidium-body">
                                        <span class="position-badge chairman-badge">
                                            {member.position}
                                        </span>
                                        <h3 class="member-name">
                                            {member.firstname} {member.lastname}
                                        </h3>
                                        <a
                                            href={`mailto:${member.email}`}
                                            class="member-email"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="13"
                                                height="13"
                                                aria-hidden="true"
                                            >
                                                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
                                            </svg>
                                            {member.email}
                                        </a>
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </div>

                <!-- ─── Divider ───────────────────────────────────────────── -->
                <div class="section-divider"></div>

                <!-- ─── Weitere Vorstandsmitglieder ──────────────────────── -->
                <div class="members-section">
                    <div class="section-header">
                        <h2 class="subsection-title">
                            Weitere Vorstandsmitglieder
                        </h2>
                    </div>

                    <div class="board-grid">
                        {
                            members.map((member) => (
                                <article class="member-card">
                                    <div class="card-img-wrap">
                                        <img
                                            src={member.imageUrl}
                                            alt={`${member.firstname} ${member.lastname}`}
                                            class="card-img"
                                            width="200"
                                            height="200"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="card-body">
                                        <span class="position-badge">
                                            {member.position}
                                        </span>
                                        <h3 class="member-name">
                                            {member.firstname} {member.lastname}
                                        </h3>
                                        <a
                                            href={`mailto:${member.email}`}
                                            class="member-email"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                width="13"
                                                height="13"
                                                aria-hidden="true"
                                            >
                                                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
                                            </svg>
                                            {member.email}
                                        </a>
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</Layout>

<style>
    /* ================================================================
     BASE LAYOUT
  ================================================================ */
    .vorstand-main {
        padding-top: var(--header-height);
        min-height: 100vh;
    }

    /* ================================================================
     PAGE HERO
  ================================================================ */
    .page-hero {
        background: var(--color-bg);
        padding: 5rem 0 4rem;
        border-bottom: 1px solid var(--color-border);
        position: relative;
        overflow: hidden;
    }

    .page-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            ellipse at 30% 60%,
            rgba(200, 16, 46, 0.08) 0%,
            transparent 65%
        );
        pointer-events: none;
    }

    .page-hero .container {
        position: relative;
    }

    .hero-badge {
        display: inline-block;
        background: var(--color-red-glow);
        border: 1px solid var(--color-border-accent);
        color: var(--color-red);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        padding: 0.3rem 0.9rem;
        border-radius: 20px;
        margin-bottom: 1.25rem;
    }

    .hero-title {
        font-size: clamp(2.25rem, 5vw, 3.5rem);
        font-weight: 800;
        color: var(--color-text);
        line-height: 1.1;
        margin-bottom: 1rem;
        padding-left: 1rem;
        border-left: 4px solid var(--color-red);
    }

    .hero-subtitle {
        color: var(--color-text-muted);
        font-size: 1.05rem;
        max-width: 560px;
        line-height: 1.7;
        padding-left: 1.25rem;
    }

    /* ================================================================
     BOARD SECTION WRAPPER
  ================================================================ */
    .board-section {
        background: var(--color-bg-alt);
        padding: 5rem 0 6rem;
    }

    /* ================================================================
     SECTION HEADERS (shared by Präsidium & Weitere)
  ================================================================ */
    .section-header {
        margin-bottom: 2rem;
    }

    .subsection-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-text);
        line-height: 1.2;
        margin: 0 0 0.35rem;
        padding-left: 1rem;
        border-left: 4px solid var(--color-red);
    }

    .subsection-subtitle {
        color: var(--color-text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        padding-left: 1.25rem;
        margin: 0;
    }

    /* ================================================================
     SECTION DIVIDER
  ================================================================ */
    .section-divider {
        height: 1px;
        background: var(--color-border);
        margin: 3.5rem 0;
        position: relative;
    }

    .section-divider::after {
        content: "";
        position: absolute;
        left: 0;
        top: -1px;
        width: 64px;
        height: 3px;
        background: var(--color-red);
    }

    /* ================================================================
     PRÄSIDIUM GRID
  ================================================================ */
    .praesidium-section {
        margin-bottom: 0;
    }

    .praesidium-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.75rem;
    }

    .praesidium-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border-accent);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2.25rem 1.75rem 2rem;
        text-align: center;
        position: relative;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .praesidium-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--color-red);
        border-radius: 16px 16px 0 0;
    }

    .praesidium-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(200, 16, 46, 0.12);
    }

    .praesidium-img-wrap {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid var(--color-red);
        box-shadow: 0 0 0 5px rgba(200, 16, 46, 0.15);
        margin-bottom: 1.25rem;
        flex-shrink: 0;
    }

    .praesidium-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .praesidium-body {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        width: 100%;
    }

    .praesidium-body .member-name {
        font-size: 1.15rem;
    }

    .praesidium-body .member-email {
        justify-content: center;
        padding-top: 0.6rem;
    }

    /* ================================================================
     MEMBERS SECTION (Weitere Vorstandsmitglieder)
  ================================================================ */
    .members-section {
        /* no extra frills – inherits section-header */
    }

    /* ================================================================
     REGULAR BOARD GRID
  ================================================================ */
    .board-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .member-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
            transform 0.2s ease,
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    .member-card:hover {
        transform: translateY(-4px);
        border-color: var(--color-border-accent);
        box-shadow: 0 8px 32px rgba(200, 16, 46, 0.08);
    }

    .card-img-wrap {
        width: 100%;
        aspect-ratio: 1;
        overflow: hidden;
        background: var(--color-surface-hover);
        position: relative;
    }

    .member-card:hover .card-img-wrap::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--color-red);
    }

    .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .card-body {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        flex: 1;
    }

    /* ================================================================
     SHARED BADGES, NAMES, EMAILS
  ================================================================ */
    .position-badge {
        display: inline-block;
        background: var(--color-red-glow);
        border: 1px solid rgba(200, 16, 46, 0.25);
        color: var(--color-red);
        font-size: 0.68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        width: fit-content;
    }

    .chairman-badge {
        background: rgba(200, 16, 46, 0.15);
        border-color: rgba(200, 16, 46, 0.4);
        color: var(--color-red);
    }

    .member-name {
        font-size: 1rem;
        font-weight: 700;
        color: var(--color-text);
        margin: 0.1rem 0 0;
        line-height: 1.25;
    }

    .member-email {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--color-text-muted);
        font-size: 0.78rem;
        text-decoration: none;
        margin-top: auto;
        padding-top: 0.5rem;
        transition: color 0.2s;
        word-break: break-all;
    }

    .member-email:hover {
        color: var(--color-red);
    }

    /* ================================================================
     RESPONSIVE
  ================================================================ */
    @media (max-width: 1100px) {
        .board-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 860px) {
        .praesidium-grid {
            grid-template-columns: 1fr;
            max-width: 420px;
            margin: 0 auto;
        }
    }

    @media (max-width: 768px) {
        .board-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .board-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .praesidium-img-wrap {
            width: 100px;
            height: 100px;
        }

        .card-body {
            padding: 1rem;
        }

        .member-name {
            font-size: 0.9rem;
        }

        .member-email {
            font-size: 0.72rem;
        }
    }
</style>
