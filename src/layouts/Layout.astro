---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "VfL Primstal",
  description = "Seit 1931 leben wir Fußball im Herzen des Saarlandes.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="https://www.vfl-primstal.de/wp-content/uploads/2018/08/Logo_vfl_middle-289x300.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #0c0c0c;
    --color-bg-alt: #141414;
    --color-surface: #1c1c1c;
    --color-surface-hover: #252525;
    --color-red: #c8102e;
    --color-red-light: #e8193e;
    --color-red-dark: #8b0000;
    --color-red-glow: rgba(200, 16, 46, 0.15);
    --color-text: #f0f0f0;
    --color-text-muted: #909090;
    --color-border: #2a2a2a;
    --color-border-accent: rgba(200, 16, 46, 0.4);
    --font: 'Inter', system-ui, -apple-system, sans-serif;
    --max-width: 1200px;
    --header-height: 72px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-text);
    padding-left: 1rem;
    border-left: 4px solid var(--color-red);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 600px;
    margin-bottom: 3rem;
    padding-left: 1.25rem;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--color-red);
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 2px solid var(--color-red);
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
    letter-spacing: 0.01em;
  }

  .btn-primary:hover {
    background-color: var(--color-red-light);
    border-color: var(--color-red-light);
    transform: translateY(-1px);
  }

  .btn-outline {
    display: inline-block;
    background-color: transparent;
    color: var(--color-red);
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 2px solid var(--color-red);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.1s ease;
    letter-spacing: 0.01em;
  }

  .btn-outline:hover {
    background-color: var(--color-red);
    color: #fff;
    transform: translateY(-1px);
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-red-dark);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-red);
  }
</style>
